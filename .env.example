# Required for new installs: one or more bot tokens for this host.
# Comma-separated bot tokens. By default, each bot gets an independent Codex runtime/auth selection.
TG_BOT_TOKENS=<telegram_bot_token>
# Backward-compatible single-runtime setup.
# In TG_BOT_TOKENS mode, if this exact token is also present in TG_BOT_TOKENS,
# that bot uses the default terminal CODEX_HOME/auth instead of an isolated home.
# TG_BOT_TOKEN=<telegram_bot_token>

# Required: only this Telegram user can control the bridge
TG_ALLOWED_USER_ID=<telegram_user_id>

# Optional: set this to allow a specific group/supergroup
TG_ALLOWED_CHAT_ID=

# Optional: set this to make one topic the default conversation scope
# Leave empty to use the whole allowed group as the default scope
TG_ALLOWED_TOPIC_ID=

# Optional Codex Desktop bridge settings.
# In TG_BOT_TOKENS mode isolated Telegram runtimes start app-server directly and
# do not auto-launch Codex Desktop; this remains applicable to the default/shared
# terminal runtime and Weixin runtime.
CODEX_APP_AUTOLAUNCH=true
CODEX_APP_LAUNCH_CMD=codex app
# Optional: persist the managed app-server pid/port and collect its stdout/stderr
CODEX_APP_SERVER_STATE_PATH=
CODEX_APP_SERVER_LOG_PATH=
CODEX_APP_SYNC_ON_OPEN=true
CODEX_APP_SYNC_ON_TURN_COMPLETE=false
STORE_PATH=
LOG_LEVEL=info
DEFAULT_CWD=/absolute/path/to/workspace
DEFAULT_APPROVAL_POLICY=on-request
DEFAULT_SANDBOX_MODE=workspace-write
TELEGRAM_POLL_INTERVAL_MS=1200
TELEGRAM_PREVIEW_THROTTLE_MS=800
THREAD_LIST_LIMIT=10
CODEX_CLI_BIN=/absolute/path/to/codex

# Optional cross-node Codex auth sync.
# Disabled by default. When enabled, FoxClaw uses Telegram Bot-to-Bot private
# messages to move encrypted auth bundles between nodes. Enable Bot-to-Bot
# Communication Mode for each node's contact bot in BotFather first.
# In TG_BOT_TOKENS multi-bot mode, the first token is the default contact bot;
# put the node's contact token first and list peer contact @usernames below.
# AUTH_SYNC_ENABLED=true
# AUTH_SYNC_KEY=<shared-key-with-at-least-32-bytes>
# AUTH_SYNC_PEERS=@other_node_bot,@third_node_bot
# AUTH_SYNC_CLUSTER_ID=my-codex-auth-pool
# AUTH_SYNC_NODE_ID=
# Resource-rich auth pool mode: unrecoverable candidates that would need repair
# are deleted automatically and propagated across auth-sync peers. /config can
# toggle this at runtime and writes AUTH_AUTO_DELETE_NEEDS_REPAIR back here.
# AUTH_AUTO_DELETE_NEEDS_REPAIR=false

# Optional: standard HTTP(S) proxy for Telegram and ChatGPT/Codex backend requests.
# Put these in the same env file that `foxclaw start` installs into systemd/launchd.
# FoxClaw passes them to the service and enables Node's env proxy support.
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7891
# NO_PROXY=127.0.0.1,localhost
# Optional Linux-only fallback when a service must run through proxychains4.
# FOXCLAW_PROXYCHAINS_CONF=/absolute/path/to/proxychains.conf

# Weixin (iLink): run `foxclaw weixin-login` once, then enable:
# WX_ENABLED=true
# Comma-separated iLink user ids allowed to chat (see account JSON linkedIlinkUserId)
# WX_ALLOWED_ILINK_USER_IDS=
# Optional: WEIXIN_ACCOUNTS_DIR, WEIXIN_SYNC_BUF_DIR, WEIXIN_MEDIA_DIR, WX_ILINK_ROUTE_TAG
